{
  "name": "aci-automacoes-comerciais-integradas-atualizado",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch --env-file=.env src/backend/server.ts",
    "start": "node --env-file=.env dist-server/server.js",
    "start:prod": "node --env-file=.env dist-server/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "build:server": "esbuild src/backend/server.ts --bundle --platform=node --target=node20 --outfile=dist-server/server.js --format=esm --packages=external",
    "build:all": "npm run build && npm run build:server",
    "preview": "vite preview",
    "test": "vitest",
    "docker:build": "docker build -t aci-automacoes:latest .",
    "docker:run": "docker run -p 4001:4001 -p 3000:3000 aci-automacoes:latest",
    "deploy": "deploy.bat",
    "setup": "node scripts/setup.js"
  },
  "dependencies": {
    "@google/genai": "^1.37.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.10.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "esbuild": "^0.27.2",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.555.0",
    "morgan": "^1.10.1",
    "motion": "^12.23.26",
    "nanoid": "^5.1.6",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.11",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.70.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "sweetalert2": "^11.26.17",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251205.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^2.0.12",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "esbuild-plugin-styled-components": "^3.0.1",
    "picomatch": "^4.0.3",
    "prisma": "^7.2.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.14",
    "wrangler": "^4.53.0"
  }
