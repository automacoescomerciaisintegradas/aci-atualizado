# ========================================
# ACI - Automações Comerciais Integradas
# ========================================
# Copie este arquivo para .env e preencha com suas credenciais
# cp .env.example .env

# ========================================
# SUPABASE
# ========================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Service Role Key - apenas para servidor/edge functions
# SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# ========================================
# OPENAI
# ========================================
OPENAI_API_KEY=sk-sua-chave-openai
OPENAI_MODEL_TEXT=gpt-4-turbo-preview
OPENAI_MODEL_IMAGE=dall-e-3
OPENAI_MAX_TOKENS=2000

# ========================================
# GOOGLE GEMINI
# ========================================
GEMINI_API_KEY=sua_chave_gemini

# ========================================
# JWT / AUTH
# ========================================
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=seu_jwt_secret_aleatorio_aqui
JWT_EXPIRES_IN=7d

# ========================================
# META / FACEBOOK / INSTAGRAM
# ========================================
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret
META_WEBHOOK_VERIFY_TOKEN=seu_webhook_token
META_REDIRECT_URI=http://localhost:4001/api/integrations/instagram/callback
META_API_VERSION=v23.0

# ========================================
# MERCADO LIVRE / MERCADO PAGO
# ========================================
ML_APP_ID=seu_ml_app_id
ML_CLIENT_SECRET=seu_ml_client_secret
ML_REDIRECT_URI=https://seu-dominio.com.br

# PIX / Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu_access_token
MERCADOPAGO_PUBLIC_KEY=sua_public_key

# ========================================
# REDIS (opcional)
# ========================================
REDIS_URL=redis://default:senha@host:porta

# ========================================
# ENCRYPTION
# ========================================
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=sua_chave_de_criptografia

# ========================================
# APP CONFIG
# ========================================
PORT=4001
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
API_URL=http://localhost:4001
VITE_API_URL=https://seu-dominio.com.br

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ========================================
# CREDITS PRICING (em reais)
# ========================================
CREDIT_COST_GPT4_PER_1K_TOKENS=0.05
CREDIT_COST_DALLE_PER_IMAGE=0.20
CREDIT_COST_INSTAGRAM_POST=0.10
CREDIT_COST_INSTAGRAM_DM=0.05
CREDIT_COST_COMMENT_REPLY=0.03

# ========================================
# SHOPEE (opcional)
# ========================================
# SHOPEE_AFFILIATE_ID=seu_id_afiliado
# SHOPEE_PARTNER_ID=seu_partner_id
# SHOPEE_PARTNER_KEY=sua_partner_key
